rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// NODE TECH — Reglas de seguridad de Firestore (v2)
//
// ESTRUCTURA SEGURA:
//   usuarios/{uid}/
//   ├── perfil/
//   ├── empleados/
//   ├── clientes/
//   ├── servicios/
//   ├── citas/           ← Nexo central
//   ├── finanzas/        ← Se alimenta automáticamente
//   ├── chatbot/
//   └── inventario/
//
// MODELO DE ACCESO:
//   • Cada usuario SOLO puede leer/escribir en su propia carpeta usuarios/{uid}/*
//   • Un usuario NO puede acceder a usuarios/{otro_uid}/*
//   • El rol "admin" puede leer y modificar cualquier documento (futuro)
//   • Todo lo que no esté explícitamente permitido queda bloqueado.
//
// VALIDACIÓN DE SEGURIDAD:
//   Frontend: DataManager valida (this.userId)
//   Firestore: Reglas validan (request.auth.uid == userId)
//   Backend: Cloud Functions validan (futura expansión)
//
// EJEMPLO DE DENEGACIÓN:
//   Juan (uid: juan123) intenta acceder a clientes de María (maria456):
//   - collection(db, 'usuarios', 'maria456', 'clientes')
//   - Regla: request.auth.uid ('juan123') != userId ('maria456')
//   - Resultado: ❌ ACCESO DENEGADO
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Comprueba si el usuario autenticado tiene role == "admin" en su propio documento.
    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Colección: usuarios (NUEVA ESTRUCTURA) ─────────────────────────────
    // Cada usuario propietario solo accede a su carpeta
    match /usuarios/{userId}/{document=**} {
      // ✅ Permitir leer/escribir SOLO si eres el propietario
      allow read, write: if isOwner(userId);
    }

    // ── Subcolecciones específicas (para mayor seguridad futura) ─────────────
    // Perfil del usuario
    match /usuarios/{userId}/perfil/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Empleados del negocio
    match /usuarios/{userId}/empleados/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Clientes del negocio
    match /usuarios/{userId}/clientes/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Servicios ofrecidos
    match /usuarios/{userId}/servicios/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Citas (El nexo central)
    match /usuarios/{userId}/citas/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Finanzas (Ingresos/Gastos)
    match /usuarios/{userId}/finanzas/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Historial del Chatbot
    match /usuarios/{userId}/chatbot/{docId} {
      allow read, write: if isOwner(userId);
    }

    // Inventario de productos
    match /usuarios/{userId}/inventario/{docId} {
      allow read, write: if isOwner(userId);
    }

    // ── Colección LEGADA: users (backwards compatibility) ─────────────────
    // Un wildcard cubre TODAS las subcolecciones de cada usuario,
    // incluyendo: caja, gastosFijos, facturas, tarifas, empleados, citas, etc.
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role   == 'user'
        && request.resource.data.status == 'active'
        && request.resource.data.uid    == userId;
      allow update: if (isOwner(userId)
          && request.resource.data.role   == resource.data.role
          && request.resource.data.status == resource.data.status)
        || isAdmin();
      allow delete: if isAdmin();
    }

    // Cubre cualquier subcolección bajo users/{userId}: caja, gastosFijos,
    // facturas, tarifas, citas, empleados, clientes, servicios, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // ── Colección LEGADA: appointments ─────────────────────────────────────
    // Descomenta si migras desde localStorage. Se recomienda usar usuarios/{uid}/citas en su lugar.
    //
    // match /appointments/{appointmentId} {
    //   allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
    //   allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    //   allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    // }

    // ── Bloquear todo lo demás ─────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
